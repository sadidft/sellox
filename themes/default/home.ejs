<div class="text-center mb-12">
  <h1 class="text-4xl font-bold mb-3"><%= store.name %></h1>
  <p class="text-zinc-400 text-lg"><%= store.description %></p>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  <% if (typeof products !== 'undefined') { %>
    <% products.forEach(function(product) { %>
      <%- include('partials/product-card', { product, store }) %>
    <% }) %>
  <% } %>
</div>

<% if (!products || products.length === 0) { %>
  <div class="text-center py-20 text-zinc-500">
    <p class="text-6xl mb-4">📦</p>
    <p class="text-xl">No products available</p>
    <p class="text-sm mt-2">Check back later!</p>
  </div>
<% } %>
