<div class="max-w-lg mx-auto">

  <% if (typeof lookupMode !== 'undefined' && lookupMode && !order) { %>
    <!-- Lookup Form -->
    <div class="text-center mb-8">
      <h2 class="text-2xl font-bold mb-2">Order Lookup</h2>
      <p class="text-zinc-400">Enter your order ID or email address</p>
    </div>

    <form method="POST" action="/orders/lookup" class="mb-6">
      <div class="flex gap-3">
        <input type="text" name="query" required
          placeholder="SLX-XXXXXXXX or you@email.com"
          value="<%= typeof query !== 'undefined' ? query : '' %>"
          class="flex-1 px-4 py-3 bg-zinc-900 rounded-lg border border-zinc-800
                 focus:border-primary focus:outline-none text-white">
        <button type="submit"
          class="px-6 py-3 bg-primary hover:opacity-90 rounded-lg font-semibold transition-opacity">
          Search
        </button>
      </div>
    </form>

    <% if (typeof notFound !== 'undefined' && notFound) { %>
      <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-8 text-center">
        <p class="text-4xl mb-3">🔍</p>
        <p class="text-zinc-400">No order found for "<%= query %>"</p>
      </div>
    <% } %>

  <% } %>

  <% if (order) { %>
    <!-- Order Details -->
    <div class="text-center mb-6">
      <h2 class="text-2xl font-bold">Order <%= order.publicId %></h2>
      <span class="inline-block mt-2 px-3 py-1 rounded-full text-sm
        <%= order.status === 'completed' ? 'bg-green-500/10 text-green-400' :
            order.status === 'pending' ? 'bg-yellow-500/10 text-yellow-400' :
            'bg-zinc-700 text-zinc-400' %>">
        <%= order.status === 'completed' ? '✅ Completed' :
            order.status === 'pending' ? '⏳ Pending Payment' :
            order.status %>
      </span>
    </div>

    <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-6 mb-6">
      <div class="space-y-2 text-sm">
        <div class="flex justify-between"><span class="text-zinc-400">Product</span><span><%= product ? product.title : order.productId %></span></div>
        <div class="flex justify-between"><span class="text-zinc-400">Quantity</span><span><%= order.quantity %></span></div>
        <div class="flex justify-between"><span class="text-zinc-400">Total</span><span class="font-bold"><%= store.currencySymbol %><%= (order.totalAmount / 100).toFixed(2) %></span></div>
        <div class="flex justify-between"><span class="text-zinc-400">Email</span><span><%= order.email %></span></div>
        <div class="flex justify-between"><span class="text-zinc-400">Date</span><span><%= new Date(order.createdAt).toLocaleString() %></span></div>
      </div>
    </div>

    <% if (order.status === 'completed' && order.deliveredContent) { %>
      <div class="bg-zinc-900 rounded-xl border border-green-500/30 p-6 mb-6">
        <h3 class="font-semibold mb-3 text-green-400 flex items-center gap-2">
          🎁 Your Product
        </h3>
        <pre class="bg-zinc-800 p-4 rounded-lg text-sm font-mono text-green-300 whitespace-pre-wrap overflow-auto max-h-80 select-all"><%= order.deliveredContent %></pre>
        <button onclick="navigator.clipboard.writeText(document.querySelector('pre').textContent).then(() => this.textContent = '✅ Copied!')"
          class="mt-3 px-4 py-2 bg-zinc-800 hover:bg-zinc-700 rounded-lg text-sm transition-colors">
          📋 Copy to Clipboard
        </button>
      </div>
    <% } else if (order.status === 'pending') { %>
      <div class="bg-yellow-500/10 border border-yellow-500/30 rounded-xl p-4 mb-6">
        <p class="text-yellow-400 text-sm">
          ⏳ Waiting for payment confirmation. This page will update once your payment is verified.
        </p>
      </div>

      <div class="text-center">
        <button onclick="location.reload()"
          class="px-6 py-2 bg-zinc-800 hover:bg-zinc-700 rounded-lg text-sm transition-colors">
          🔄 Refresh Status
        </button>
      </div>
    <% } %>

    <div class="text-center mt-6">
      <a href="/" class="text-sm text-zinc-500 hover:text-white">← Back to store</a>
    </div>

  <% } %>
</div>
