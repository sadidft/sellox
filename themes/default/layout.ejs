<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %><%= store.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { colors: { primary: '<%= store.colors.primary %>' } } }
    }
  </script>
  <style>
    :root { --color-primary: <%= store.colors.primary %>; }
    body { font-family: system-ui, -apple-system, sans-serif; }
  </style>
</head>
<body class="bg-zinc-950 text-zinc-50 min-h-screen flex flex-col">

  <%- include('partials/header') %>

  <main class="flex-1 max-w-6xl mx-auto px-4 py-8 w-full">
    <%- body %>
  </main>

  <%- include('partials/footer') %>

</body>
</html>
