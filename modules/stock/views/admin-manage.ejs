<div class="flex items-center justify-between mb-6">
  <div>
    <h2 class="text-2xl font-bold">Stock: <%= product.title %></h2>
    <p class="text-zinc-500 text-sm"><%= available.length %> available, <%= sold.length %> sold</p>
  </div>
  <a href="/admin/products" class="px-4 py-2 bg-zinc-800 rounded-lg text-sm hover:bg-zinc-700">← Back</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <!-- Add Single -->
  <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-6">
    <h3 class="font-semibold mb-4">Add Single Item</h3>
    <form method="POST" action="/admin/stock/<%= product.id %>/add" class="space-y-3">
      <textarea name="content" rows="3" required placeholder="account@email.com:password123"
        class="w-full px-4 py-3 bg-zinc-800 rounded-lg border border-zinc-700 focus:border-primary focus:outline-none text-white text-sm font-mono"></textarea>
      <button type="submit" class="px-4 py-2 bg-primary rounded-lg text-sm hover:opacity-90">Add Item</button>
    </form>
  </div>

  <!-- Bulk Upload -->
  <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-6">
    <h3 class="font-semibold mb-4">Bulk Upload</h3>
    <form method="POST" action="/admin/stock/<%= product.id %>/bulk" class="space-y-3">
      <textarea name="bulk" rows="6" required
        placeholder="item1&#10;item2&#10;item3&#10;(one per line)"
        class="w-full px-4 py-3 bg-zinc-800 rounded-lg border border-zinc-700 focus:border-primary focus:outline-none text-white text-sm font-mono"></textarea>
      <div class="flex items-center gap-3">
        <select name="delimiter" class="px-3 py-2 bg-zinc-800 rounded-lg border border-zinc-700 text-sm text-white">
          <option value="newline">One per line</option>
          <option value="---">Separated by ---</option>
        </select>
        <button type="submit" class="px-4 py-2 bg-primary rounded-lg text-sm hover:opacity-90">Upload All</button>
      </div>
    </form>
  </div>
</div>

<!-- Available Stock -->
<div class="mt-6 bg-zinc-900 rounded-xl border border-zinc-800 overflow-hidden">
  <div class="px-4 py-3 border-b border-zinc-800">
    <h3 class="font-semibold">Available Stock (<%= available.length %>)</h3>
  </div>
  <table class="w-full text-sm">
    <tbody>
      <% available.forEach(function(item) { %>
        <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/30">
          <td class="py-2 px-4 font-mono text-xs text-zinc-300 max-w-md truncate"><%= item.content %></td>
          <td class="py-2 px-4 text-right">
            <form method="POST" action="/admin/stock/delete/<%= item.id %>" class="inline"
                  onsubmit="return confirm('Delete?')">
              <button class="text-red-400 hover:text-red-300 text-xs">✕</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (available.length === 0) { %>
        <tr><td colspan="2" class="py-8 text-center text-zinc-500">No stock items</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
