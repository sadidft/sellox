<h2 class="text-2xl font-bold mb-6">Manual Payments</h2>
<p class="text-zinc-400 mb-6">Pending orders paid via bank transfer. Confirm after verifying payment.</p>

<div class="space-y-4">
  <% orders.forEach(function(o) { %>
    <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-6 flex items-center justify-between">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <span class="font-mono text-sm text-primary"><%= o.publicId %></span>
          <span class="px-2 py-1 bg-yellow-500/10 text-yellow-400 rounded-full text-xs">pending</span>
        </div>
        <p class="text-sm text-zinc-400">
          <%= o.email %> — <%= o.product ? o.product.title : o.productId %>
          × <%= o.quantity %>
        </p>
        <p class="text-lg font-bold mt-1"><%= store.currencySymbol %><%= (o.totalAmount / 100).toFixed(2) %></p>
        <p class="text-xs text-zinc-500"><%= new Date(o.createdAt).toLocaleString() %></p>
      </div>
      <form method="POST" action="/admin/pay-manual/confirm/<%= o.id %>"
            onsubmit="return confirm('Confirm payment for <%= o.publicId %>?')">
        <button type="submit" class="px-6 py-3 bg-green-600 hover:bg-green-700 rounded-lg text-sm font-semibold transition-colors">
          ✅ Confirm Paid
        </button>
      </form>
    </div>
  <% }) %>

  <% if (orders.length === 0) { %>
    <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-12 text-center text-zinc-500">
      <p class="text-4xl mb-3">✅</p>
      <p>No pending manual payments</p>
    </div>
  <% } %>
</div>
