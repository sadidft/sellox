<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>Admin — <%= store.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { colors: { primary: '<%= store.colors.primary %>' } } }
    }
  </script>
</head>
<body class="bg-zinc-950 text-zinc-50 min-h-screen flex">

  <%- include('partials/sidebar') %>

  <main class="flex-1 p-8 overflow-auto min-h-screen">
    <%- body %>
  </main>

</body>
</html>
