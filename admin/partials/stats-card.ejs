<% /* Usage: include('partials/stats-card', { stat: { icon, label, value } }) */ %>
<div class="bg-zinc-900 rounded-xl p-5 border border-zinc-800">
  <div class="flex items-center justify-between">
    <span class="text-zinc-400 text-sm"><%= stat.label %></span>
    <span class="text-2xl"><%= stat.icon %></span>
  </div>
  <p class="text-3xl font-bold mt-2"><%= stat.value %></p>
</div>
