<h2 class="text-2xl font-bold mb-6">Settings</h2>

<% if (typeof sections !== 'undefined') { %>
  <% sections.forEach(function(section) { %>
    <div class="bg-zinc-900 rounded-xl border border-zinc-800 p-6 mb-6">
      <h3 class="text-lg font-semibold mb-1 capitalize"><%= section.name.replace(/-/g, ' ') %></h3>
      <% if (section.description) { %>
        <p class="text-zinc-500 text-sm mb-4"><%= section.description %></p>
      <% } %>

      <form method="POST" action="/admin/settings" class="space-y-4">
        <% section.fields.forEach(function(field) { %>
          <div>
            <label class="text-sm text-zinc-400 block mb-1"><%= field.label %></label>

            <% if (field.type === 'textarea') { %>
              <textarea name="<%= field.key %>" rows="3"
                class="w-full px-4 py-3 bg-zinc-800 rounded-lg border border-zinc-700
                       focus:border-primary focus:outline-none text-white text-sm"
              ><%= section.values[field.key] || '' %></textarea>

            <% } else if (field.type === 'select') { %>
              <select name="<%= field.key %>"
                class="w-full px-4 py-3 bg-zinc-800 rounded-lg border border-zinc-700
                       focus:border-primary focus:outline-none text-white text-sm">
                <% (field.options || []).forEach(function(opt) { %>
                  <option value="<%= opt %>" <%= section.values[field.key] === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>

            <% } else { %>
              <input type="<%= field.type === 'password' ? 'password' : 'text' %>"
                     name="<%= field.key %>"
                     value="<%= field.type !== 'password' ? (section.values[field.key] || '') : '' %>"
                     placeholder="<%= field.hint || '' %>"
                class="w-full px-4 py-3 bg-zinc-800 rounded-lg border border-zinc-700
                       focus:border-primary focus:outline-none text-white text-sm">
            <% } %>
          </div>
        <% }) %>

        <button type="submit"
          class="px-6 py-2 bg-primary rounded-lg text-sm font-medium hover:opacity-90 transition-opacity">
          Save
        </button>
      </form>
    </div>
  <% }) %>
<% } %>
